{
  "manifest_version": 3,
  "name": "Maya — Your Digital Twin",
  "version": "1.0.0",
  "description": "Maya watches what you do and keeps you accountable — everywhere.",
  "permissions": ["tabs", "storage", "alarms", "activeTab"],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:3005/*",
    "http://localhost:3001/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches":    ["<all_urls>"],
      "js":         ["content.js"],
      "run_at":     "document_end",
      "all_frames": false,
      "exclude_matches": ["http://localhost:3005/*", "http://localhost:3001/*"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Maya"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
